 "custom_format": 1,
 "disabled": 0,
 "doc_type": "Daily Refreshment Log",
 "docstatus": 0,
 "doctype": "Print Format",
 "font": "Default",
 "font_size": 14,
 "html": "<div class=\"print-format\" style=\"font-family: Arial, sans-serif; color: #222;\">\n\t<div style=\"text-align:center; margin-bottom: 20px; border-bottom: 2px solid #333; padding-bottom: 10px;\">\n\t\t<h2 style=\"margin: 0;\">Daily Refreshment Log</h2>\n\t\t<div style=\"color:#666;\">TeaTorium Monthly Reconciliation</div>\n\t</div>\n\n\t<table style=\"width:100%; margin-bottom: 18px; border-collapse: collapse;\">\n\t\t<tr>\n\t\t\t<td style=\"width:50%; padding:4px 0;\"><b>Log Number:</b> {{ doc.name }}</td>\n\t\t\t<td style=\"width:50%; padding:4px 0;\"><b>Date:</b> {{ frappe.utils.formatdate(doc.date) }}</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td style=\"padding:4px 0;\"><b>Supplier:</b> {{ doc.supplier }}</td>\n\t\t\t<td style=\"padding:4px 0;\"><b>Contact:</b> {{ doc.contact or \"\" }}</td>\n\t\t</tr>\n\t</table>\n\n\t<table style=\"width:100%; border-collapse: collapse; margin-bottom: 18px;\">\n\t\t<thead>\n\t\t\t<tr>\n\t\t\t\t<th style=\"border:1px solid #ccc; padding:6px; background:#f5f5f5; text-align:left;\">Item</th>\n\t\t\t\t<th style=\"border:1px solid #ccc; padding:6px; background:#f5f5f5; text-align:right;\">Qty</th>\n\t\t\t\t<th style=\"border:1px solid #ccc; padding:6px; background:#f5f5f5; text-align:right;\">Rate</th>\n\t\t\t\t<th style=\"border:1px solid #ccc; padding:6px; background:#f5f5f5; text-align:right;\">Amount</th>\n\t\t\t</tr>\n\t\t</thead>\n\t\t<tbody>\n\t\t\t{% for row in doc.items %}\n\t\t\t<tr>\n\t\t\t\t<td style=\"border:1px solid #ccc; padding:6px;\">{{ row.item }}</td>\n\t\t\t\t<td style=\"border:1px solid #ccc; padding:6px; text-align:right;\">{{ row.qty }}</td>\n\t\t\t\t<td style=\"border:1px solid #ccc; padding:6px; text-align:right;\">{{ row.get_formatted(\"rate\", doc) }}</td>\n\t\t\t\t<td style=\"border:1px solid #ccc; padding:6px; text-align:right;\">{{ row.get_formatted(\"amount\", doc) }}</td>\n\t\t\t</tr>\n\t\t\t{% endfor %}\n\t\t</tbody>\n\t\t<tfoot>\n\t\t\t<tr>\n\t\t\t\t<td colspan=\"3\" style=\"border:1px solid #ccc; padding:6px; text-align:right;\"><b>Total Amount</b></td>\n\t\t\t\t<td style=\"border:1px solid #ccc; padding:6px; text-align:right;\"><b>{{ doc.get_formatted(\"total_amount\") }}</b></td>\n\t\t\t</tr>\n\t\t</tfoot>\n\t</table>\n\n\t<table style=\"width:100%; margin-top: 40px;\">\n\t\t<tr>\n\t\t\t<td style=\"width:50%;\">\n\t\t\t\t<div style=\"border-top:1px solid #333; width:220px; margin-top:40px; padding-top:4px;\">\n\t\t\t\t\tPrepared by: {{ frappe.db.get_value(\"Employee\", doc.order_by, \"employee_name\") or doc.order_by }}\n\t\t\t\t</div>\n\t\t\t</td>\n\t\t\t<td style=\"width:50%;\">\n\t\t\t\t<div style=\"border-top:1px solid #333; width:220px; margin-top:40px; padding-top:4px;\">\n\t\t\t\t\tReceived by (TeaTorium)\n\t\t\t\t</div>\n\t\t\t</td>\n\t\t</tr>\n\t</table>\n</div>",
 "line_breaks": 0,
 "margin_bottom": 15.0,
 "margin_left": 15.0,
 "margin_right": 15.0,
 "margin_top": 15.0,
 "module": "SnackTrack",
 "name": "Daily Refreshment Log Print",
 "owner": "Administrator",
